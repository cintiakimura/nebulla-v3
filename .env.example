# Server (optional; use if 3000 / 24678 are already in use)
# PORT=3001
# VITE_HMR_PORT=24679
# DISABLE_HMR=true

# --- Render (production) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   # from Render PostgreSQL → Connect → External URL
# DATABASE_SSL=   # omit or true for managed TLS; set "false" only for local Postgres without SSL
# SESSION_SECRET=   # strong random string (JWT signing + cookies)
# PUBLIC_SITE_URL=https://your-service.onrender.com   # public HTTPS URL of this Web Service (OAuth redirects)

# Localhost-only auth bypass (dev UX mode). When true, app auto-signs in with the profile below.
# DEV_LOCAL_AUTH=true
# DEV_LOCAL_GITHUB_UID=github-local-dev
# DEV_LOCAL_GITHUB_NAME=Your Name
# DEV_LOCAL_GITHUB_EMAIL=you@github.local
# DEV_LOCAL_GITHUB_AVATAR=https://avatars.githubusercontent.com/u/9919?v=4

# Optional: when the browser origin differs from the public site (e.g. tunneling), set for OAuth hint URLs in the client bundle
# VITE_PUBLIC_SITE_URL=https://your-service.onrender.com

# AI — Grok 4 (brain: chat + code orchestration)
GROK_API_KEY=

# Grok B — writer (Master Plan only; separate from brain)
GROK_3_API_KEY=
# Optional override (default: grok-4-1-fast-reasoning)
# GROK_B_MODEL=grok-4-1-fast-reasoning

# Stripe
STRIPE_SECRET_KEY=
PUBLIC_STRIPE_PUBLIC_KEY=

# Nebula UI Studio engine
PENCIL_API_KEY=
# Optional override
# PENCIL_API_URL=https://api.pencil.dev/v1/mockups/generate

# GROK TTS (new API)
GROK_TTS_NEW_API_KEY=

# OAuth (server secrets — register callbacks on GitHub / Google using PUBLIC_SITE_URL + /api/auth/.../callback)
# Google: OAuth consent screen → User type "External" (not Internal). Publish "In production" for any Google account.
#         OAuth client type "Web application"; redirect = PUBLIC_SITE_URL + /api/auth/google/callback
# GitHub: Create a normal "OAuth App" (Developer settings) so any GitHub user can authorize; callback = .../api/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Nebula / Nebulla deploy architecture (internal; never expose workspace IDs to the browser)
# Main Render account: nebulla.dev.ai@gmail.com | Public app domain family: nebulla.dev
# One Render workspace per client; workspace ID = permanent internal client ID (server-side secrets only).
# RENDER_API_KEY=

# Nebula Guardian — silent error memory (server). Hub: GET /api/guardian/hub?key=YOUR_SECRET
# GUARDIAN_HUB_SECRET=min-16-chars-random
# Optional: same value in Vite for silent browser error reports (never expose hub secret in the client bundle)
# GUARDIAN_REPORT_KEY=match-in-vite
# VITE_GUARDIAN_REPORT_KEY=match-in-vite
