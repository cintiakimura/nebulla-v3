{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/config",
      "destination": "/api/config"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/auth/callback",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/health.ts": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/config.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
